{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}
      ]
    },
    {
      "source": "/(.*\\.jpg)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=2592000"}
      ]
    },
    {
      "source": "/(.*\\.svg)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=2592000"}
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=604800"}
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=604800"}
      ]
    },
    {
      "source": "/(.*\\.woff2?)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}
      ]
    }
  ]
}
